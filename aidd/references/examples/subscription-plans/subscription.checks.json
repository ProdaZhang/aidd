{
  "_about": "value_check domain rules for the subscription app example. Tier-ladder coverage + monotonic.",
  "rules": [
    { "type": "coverage",  "desc": "planTier covers tiers 1~3 contiguously", "table": "planTier", "field": "tier", "min": 1, "max": 3 },
    { "type": "monotonic", "desc": "seat limit non-decreasing with tier",    "table": "planTier", "field": "seats",     "order_field": "tier" },
    { "type": "monotonic", "desc": "project limit non-decreasing with tier", "table": "planTier", "field": "projects",  "order_field": "tier" },
    { "type": "monotonic", "desc": "storage limit non-decreasing with tier", "table": "planTier", "field": "storageGb", "order_field": "tier" },
    { "type": "monotonic", "desc": "api/day non-decreasing with tier",       "table": "planTier", "field": "apiPerDay", "order_field": "tier" }
  ]
}
